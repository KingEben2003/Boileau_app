# =============================================================================
# BOILEAU — Variables d'environnement backend (Django)
# Copiez ce fichier en ".env" et remplissez chaque valeur.
# Ne committez JAMAIS le fichier .env dans Git.
# =============================================================================


# ── Django core ───────────────────────────────────────────────────────────────

# Clé secrète Django — OBLIGATOIRE en production.
# Génération : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi-en-production

# false en production (désactive les pages d'erreur détaillées).
DEBUG=true

# Domaines autorisés séparés par des virgules.
# Prod exemple : boileau.app,www.boileau.app
ALLOWED_HOSTS=localhost,127.0.0.1


# ── Base de données ───────────────────────────────────────────────────────────

# PostgreSQL (recommandé) :
#   postgres://USER:MOT_DE_PASSE@HOST:PORT/NOM_DB
# MySQL :
#   mysql://USER:MOT_DE_PASSE@HOST:PORT/NOM_DB
DATABASE_URL=postgres://postgres:motdepasse@localhost:5432/boileau_db


# ── WebSockets / Redis ────────────────────────────────────────────────────────

# Laisser vide en dev → couche mémoire (mono-process).
# Obligatoire en production multi-workers.
# Exemple : redis://localhost:6379/0
# Render/Railway fournissent une URL automatiquement.
REDIS_URL=


# ── Google OAuth ──────────────────────────────────────────────────────────────

# Client ID → console.cloud.google.com > Identifiants > OAuth 2.0
GOOGLE_CLIENT_ID=


# ── OneSignal (notifications push) ────────────────────────────────────────────

# App ID → dashboard.onesignal.com > votre app > Settings > Keys & IDs
ONESIGNAL_APP_ID=


# ── Gemini (IA — résumés & quiz) ──────────────────────────────────────────────

# Clé API → aistudio.google.com/apikey
GEMINI_API_KEY=

# Modèle à utiliser (sans le préfixe "models/").
GEMINI_MODEL=gemini-2.5-flash

# Timeout HTTP (secondes) pour les appels Gemini.
GEMINI_TIMEOUT_SECONDS=45

# Nombre max de caractères du texte source envoyé dans le prompt.
GEMINI_SOURCE_MAX_CHARS=12000

# true = mode simulation, répond sans appeler l'API (utile en dev/CI).
GEMINI_MOCK_MODE=false


# ── Email ─────────────────────────────────────────────────────────────────────

# Dev : les emails s'affichent dans la console (valeur par défaut).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production : décommentez et remplissez ces lignes.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=votre-email@gmail.com
# EMAIL_HOST_PASSWORD=votre-app-password-gmail   # Mot de passe d'application Gmail
# DEFAULT_FROM_EMAIL=noreply@boileau.app


# ── JWT / Cookies (optionnel — valeurs calculées automatiquement) ─────────────

# Secure=True est automatique quand DEBUG=false (HTTPS obligatoire en prod).
# Forcer à false uniquement si dev HTTPS local sans certificat valide.
# JWT_AUTH_COOKIE_SECURE=false

# Politique SameSite des cookies JWT.
# JWT_AUTH_COOKIE_SAMESITE=Lax
