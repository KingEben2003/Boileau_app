# Copy this file to .env and fill in your real values.

# ── API Backend ───────────────────────────────────────────────────────────────
# Décommenter en production (la valeur est proxyfied en dev)
# REACT_APP_API_BASE_URL=https://votre-domaine.com/api

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Obtenir sur https://console.cloud.google.com → APIs & Services → Credentials
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── OneSignal Web Push ────────────────────────────────────────────────────────
# Obtenir sur https://app.onesignal.com → votre app → Keys & IDs
REACT_APP_ONESIGNAL_APP_ID=your-onesignal-app-id
